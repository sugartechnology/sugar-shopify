# Production Docker — kopyala: cp .env.production.example .env.production
# Çalıştır: docker compose -f docker-compose.prod.yml up -d --build

NODE_ENV=production
HOST=0.0.0.0
PORT=3000
APP_PORT=3000

# Shopify Partners → Sugar Room Studio app
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SCOPES=read_products,write_products
SHOPIFY_APP_URL=https://storefront.sugartech.io

# OAuth session (SQLite — docker volume'da kalır)
DATABASE_URL=file:/app/prisma/prod.sqlite

# Canlı Sugar AI API
SUGAR_API_BASE_URL=https://api.sugartech.io
SHOPIFY_SERVICE_SECRET=
SUGAR_API_MOCK=false

# Opsiyonel
# SHOP_CUSTOM_DOMAIN=
