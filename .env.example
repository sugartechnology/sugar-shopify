# Ortam şablonları:
#   Local Docker  → cp .env.local.example .env.local
#   Production    → cp .env.production.example .env.production
#
# Native dev (Docker olmadan):
#   cp .env.local.example .env
#   DATABASE_URL=file:./prisma/dev.sqlite

NODE_ENV=development
HOST=0.0.0.0
PORT=3000

SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SCOPES=read_products,write_products
SHOPIFY_APP_URL=https://your-tunnel-url.example.com

DATABASE_URL=file:./prisma/dev.sqlite

SUGAR_API_BASE_URL=https://api.sugartech.io
SUGAR_API_MOCK=false
SHOPIFY_SERVICE_SECRET=
