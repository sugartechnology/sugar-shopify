{% comment %}
  Shared Sugar PDP markup. Render with:
  {% render 'sugar-pdp-root', settings: section.settings, sugar_attributes: section.shopify_attributes %}
{% endcomment %}

{{ 'sugar-pdp.css' | asset_url | stylesheet_tag }}
<script src="{{ 'sugar-pdp-core.js' | asset_url }}" defer></script>
<script src="{{ 'sugar-upload-hero.js' | asset_url }}" defer></script>
<script src="{{ 'sugar-mockup-editor.js' | asset_url }}" defer></script>
<script src="{{ 'sugar-compare-slider.js' | asset_url }}" defer></script>
<script src="{{ 'sugar-saved-designs.js' | asset_url }}" defer></script>
<script src="{{ 'sugar-pdp.js' | asset_url }}" defer></script>

{%- liquid
  assign selected_variant = product.selected_or_first_available_variant
  assign mf = shop.metafields.sugar_shopify
  assign collection_handle = settings.collection | default: mf.product_collection_handle
  assign shop_locale = request.locale.iso_code | default: localization.language.iso_code | default: 'tr'

  assign button_label = settings.button_label | default: mf.button_label
  if button_label == blank
    assign button_label = 'sugar.button_label' | t
  endif
  assign button_helper = settings.button_helper | default: mf.button_helper_text
  if button_helper == blank
    assign button_helper = 'sugar.button_helper' | t
  endif
  assign modal_title = settings.modal_title | default: mf.modal_title
  if modal_title == blank
    assign modal_title = 'sugar.modal_title' | t
  endif
  assign modal_subtitle = settings.modal_subtitle | default: mf.modal_subtitle
  if modal_subtitle == blank
    assign modal_subtitle = 'sugar.modal_subtitle' | t
  endif
  assign modal_description = settings.modal_description | default: mf.modal_description
  if modal_description == blank
    assign modal_description = 'sugar.modal_description' | t
  endif
  assign instruction = settings.instruction | default: mf.instruction_template
  if instruction == blank
    assign instruction = 'sugar.instruction' | t
  endif
  assign add_cart_label = settings.add_cart_label | default: mf.add_design_to_cart_label
  if add_cart_label == blank
    assign add_cart_label = 'sugar.add_cart_label' | t
  endif
  assign loading_title = mf.loading_title
  if loading_title == blank
    assign loading_title = 'sugar.loading_title' | t
  endif
  assign loading_subtitle = mf.loading_subtitle
  if loading_subtitle == blank
    assign loading_subtitle = 'sugar.loading_subtitle' | t
  endif
  assign image_property_key = mf.image_property_key | default: '_sugar_design_image'
  assign generation_id_key = mf.generation_id_property_key | default: '_sugar_generation_id'
  assign max_upload_mb = mf.max_upload_size_mb | default: '10'
  assign max_additional = mf.max_additional_products | default: '4'
  assign max_design_attempts = settings.max_design_attempts | default: 3
  assign product_detail_metafields_default = '[{"namespace":"custom","key":"material","label":"Malzeme"},{"namespace":"custom","key":"dimensions","label":"Ölçü"},{"namespace":"custom","key":"color","label":"Renk"}]'
  assign product_detail_metafields_json = settings.product_detail_metafields | default: product_detail_metafields_default
  assign product_detail_metafield_namespace = settings.product_detail_metafield_namespace | default: 'custom'
  assign custom_css = mf.custom_css
  assign hero_url = mf.hero_image_url
  assign upload_illustration_url = mf.upload_illustration_url | default: hero_url
  assign header_icon_url = settings.header_icon | default: mf.header_icon_url
  assign gallery_icon_url = mf.gallery_icon_url
  assign camera_icon_url = mf.camera_icon_url

  if settings.gallery_icon != blank
    assign gallery_icon_url = settings.gallery_icon | image_url: width: 56
  elsif settings.gallery_icon_url != blank
    assign gallery_icon_url = settings.gallery_icon_url
  endif

  if settings.camera_icon != blank
    assign camera_icon_url = settings.camera_icon | image_url: width: 56
  elsif settings.camera_icon_url != blank
    assign camera_icon_url = settings.camera_icon_url
  endif

  if settings.upload_illustration != blank
    assign upload_illustration_url = settings.upload_illustration | image_url: width: 900
  elsif settings.upload_illustration_url != blank
    assign upload_illustration_url = settings.upload_illustration_url
  elsif settings.hero_image != blank
    assign upload_illustration_url = settings.hero_image | image_url: width: 900
  endif

  if upload_illustration_url == blank
    assign upload_illustration_url = 'shopify-image-ai-flow.png' | asset_url
  endif

  assign upload_illustration_fit = settings.upload_illustration_fit | default: mf.upload_illustration_fit | default: 'cover'
  if upload_illustration_fit != 'contain'
    assign upload_illustration_fit = 'cover'
  endif

  assign ai_btn_classes = settings.ai_button_classes | default: mf.ai_button_classes | default: 'sugar-ai-btn'
  assign secondary_classes = settings.secondary_button_classes | default: mf.secondary_button_classes | default: 'button button--secondary'
  assign primary_classes = settings.primary_button_classes | default: mf.primary_button_classes | default: 'button button--primary'
  assign modal_panel_classes = settings.modal_panel_classes | default: mf.modal_panel_classes

  assign theme_preset = settings.theme_preset | default: mf.theme_preset | default: 'dawn'
  if theme_preset == 'dawn'
    if settings.ai_button_classes == blank and mf.ai_button_classes == blank
      assign ai_btn_classes = 'sugar-ai-btn'
    endif
    if settings.primary_button_classes == blank and mf.primary_button_classes == blank
      assign primary_classes = 'button button--primary'
    endif
    if settings.secondary_button_classes == blank and mf.secondary_button_classes == blank
      assign secondary_classes = 'button button--secondary'
    endif
  elsif theme_preset == 'normod'
    if settings.primary_button_classes == blank and mf.primary_button_classes == blank
      assign primary_classes = 'button button--primary'
    endif
    if settings.secondary_button_classes == blank and mf.secondary_button_classes == blank
      assign secondary_classes = 'button button--secondary'
    endif
  endif

  assign skip_product_selection = settings.skip_product_selection
  if skip_product_selection == false and mf.skip_product_selection == 'true'
    assign skip_product_selection = true
  endif

  assign product_images = product.media | where: 'media_type', 'image'
  assign primary_image = selected_variant.featured_media | default: product.featured_media
  if primary_image == blank and product_images.size > 0
    assign primary_image = product_images.first
  endif

  assign modal_bg_color = settings.modal_bg_color | default: mf.modal_bg_color
  assign modal_text_color = settings.modal_text_color | default: mf.modal_text_color
  assign accent_color = settings.accent_color | default: mf.accent_color | default: '#c4a574'
  assign overlay_color = settings.overlay_color | default: mf.overlay_color | default: 'rgba(0, 0, 0, 0.55)'
  assign modal_radius_setting = settings.modal_radius | default: mf.modal_radius | default: 16
  assign font_scale_pct = settings.font_scale | default: mf.font_scale | default: 100
  assign file_uid = product.id
  assign shop_currency = cart.currency.iso_code | default: shop.currency

  assign related_ns = settings.related_products_namespace | default: mf.related_products_namespace | default: 'custom'
  assign related_key = settings.related_products_key | default: mf.related_products_key | default: 'related_products'
  assign related_products = product.metafields[related_ns][related_key].value
-%}

{%- capture sugar_css_vars -%}
{%- if theme_preset == 'dawn' -%}
--sugar-modal-bg: rgb(var(--color-background, 255 255 255));
--sugar-text: rgb(var(--color-foreground, 18 18 18));
--sugar-muted: rgba(var(--color-foreground, 18 18 18), 0.65);
--sugar-border: rgba(var(--color-foreground, 18 18 18), 0.12);
--sugar-modal-radius: var(--buttons-radius, var(--button-border-radius, 16px));
--sugar-btn-bg: rgb(var(--color-background, 255 255 255));
--sugar-btn-color: rgb(var(--color-foreground, 18 18 18));
{%- elsif theme_preset == 'normod' -%}
--sugar-modal-bg: rgb(var(--color-background, 255 255 255));
--sugar-text: rgb(var(--color-foreground, 18 18 18));
--sugar-muted: rgba(var(--color-foreground, 18 18 18), 0.65);
--sugar-border: rgba(var(--color-foreground, 18 18 18), 0.12);
--sugar-modal-radius: var(--buttons-radius, 16px);
--sugar-btn-bg: rgb(var(--color-background, 255 255 255));
--sugar-btn-color: rgb(var(--color-foreground, 18 18 18));
{%- else -%}
--sugar-modal-bg: {{ modal_bg_color | default: mf.modal_bg_color | default: '#ffffff' }};
--sugar-text: {{ modal_text_color | default: mf.modal_text_color | default: '#121212' }};
--sugar-muted: #6b7280;
--sugar-border: rgba(0, 0, 0, 0.12);
--sugar-modal-radius: {{ modal_radius_setting }}px;
--sugar-btn-bg: {{ modal_bg_color | default: mf.modal_bg_color | default: '#ffffff' }};
--sugar-btn-color: {{ modal_text_color | default: mf.modal_text_color | default: '#121212' }};
{%- endif -%}
--sugar-accent: {{ accent_color }};
--sugar-accent-soft: color-mix(in srgb, {{ accent_color }} 14%, #ffffff);
--sugar-icon-accent: {{ accent_color }};
--sugar-icon-on-accent: #ffffff;
--sugar-hero-bg: #f3eee6;
--sugar-upload-fit: {{ upload_illustration_fit }};
--sugar-overlay-bg: {{ overlay_color }};
--sugar-modal-shadow: 0 24px 64px rgba(0, 0, 0, 0.18);
--sugar-font-scale: {{ font_scale_pct | divided_by: 100.0 }};
{%- if theme_preset == 'dawn' or theme_preset == 'normod' -%}
{%- if settings.modal_bg_color != blank or mf.modal_bg_color != blank -%}
--sugar-modal-bg: {{ modal_bg_color }};
--sugar-btn-bg: {{ modal_bg_color }};
{%- endif -%}
{%- if settings.modal_text_color != blank or mf.modal_text_color != blank -%}
--sugar-text: {{ modal_text_color }};
--sugar-btn-color: {{ modal_text_color }};
{%- endif -%}
{%- if settings.modal_radius != blank or mf.modal_radius != blank -%}
--sugar-modal-radius: {{ modal_radius_setting }}px;
{%- endif -%}
{%- endif -%}
{%- if settings.accent_color != blank or mf.accent_color != blank -%}
--sugar-accent: {{ accent_color }};
{%- endif -%}
{%- if settings.overlay_color != blank or mf.overlay_color != blank -%}
--sugar-overlay-bg: {{ overlay_color }};
{%- endif -%}
{%- endcapture -%}

{%- capture variants_json -%}
[
{%- for variant in product.variants -%}
  {%- assign v_img = variant.featured_media | default: product.featured_media -%}
  {%- if v_img == blank and product_images.size > 0 -%}
    {%- assign v_img = product_images.first -%}
  {%- endif -%}
  {
    "variantId": {{ variant.id | json }},
    "price": {{ variant.price | json }},
    "imageUrl": {{ v_img | image_url: width: 800 | json }}
  }{% unless forloop.last %},{% endunless %}
{%- endfor -%}
]
{%- endcapture -%}

{%- capture primary_images_json -%}
[
{%- assign primary_img_count = 0 -%}
{%- for media in product.media -%}
  {%- if primary_img_count >= 3 -%}{%- break -%}{%- endif -%}
  {%- if media.media_type == 'image' -%}
    {%- if primary_img_count > 0 -%},{%- endif -%}
    {{ media | image_url: width: 800 | json }}
    {%- assign primary_img_count = primary_img_count | plus: 1 -%}
  {%- endif -%}
{%- endfor -%}
]
{%- endcapture -%}

{%- capture catalog_json -%}
[
{%- if related_products != blank -%}
  {%- for cat_product in related_products limit: 12 -%}
    {%- assign cat_variant = cat_product.selected_or_first_available_variant -%}
    {%- assign cat_img = cat_variant.featured_media | default: cat_product.featured_media -%}
    {%- unless forloop.first -%},{%- endunless -%}
    {
      "productId": {{ cat_product.id | json }},
      "variantId": {{ cat_variant.id | json }},
      "title": {{ cat_product.title | json }},
      "price": {{ cat_variant.price | json }},
      "currency": {{ shop_currency | json }},
      "imageUrl": {{ cat_img | image_url: width: 400 | json }},
      "images": [
        {%- assign rel_img_count = 0 -%}
        {%- for media in cat_product.media -%}
          {%- if rel_img_count >= 3 -%}{%- break -%}{%- endif -%}
          {%- if media.media_type == 'image' -%}
            {%- if rel_img_count > 0 -%},{%- endif -%}
            {{ media | image_url: width: 800 | json }}
            {%- assign rel_img_count = rel_img_count | plus: 1 -%}
          {%- endif -%}
        {%- endfor -%}
      ]
    }
  {%- endfor -%}
{%- elsif collection_handle != blank and collections[collection_handle] -%}
  {%- for cat_product in collections[collection_handle].products limit: 20 -%}
    {%- assign cat_variant = cat_product.selected_or_first_available_variant -%}
    {%- assign cat_img = cat_variant.featured_media | default: cat_product.featured_media -%}
    {%- unless forloop.first -%},{%- endunless -%}
    {
      "productId": {{ cat_product.id | json }},
      "variantId": {{ cat_variant.id | json }},
      "title": {{ cat_product.title | json }},
      "price": {{ cat_variant.price | json }},
      "currency": {{ shop_currency | json }},
      "imageUrl": {{ cat_img | image_url: width: 400 | json }},
      "images": [
        {%- assign col_img_count = 0 -%}
        {%- for media in cat_product.media -%}
          {%- if col_img_count >= 3 -%}{%- break -%}{%- endif -%}
          {%- if media.media_type == 'image' -%}
            {%- if col_img_count > 0 -%},{%- endif -%}
            {{ media | image_url: width: 800 | json }}
            {%- assign col_img_count = col_img_count | plus: 1 -%}
          {%- endif -%}
        {%- endfor -%}
      ]
    }
  {%- endfor -%}
{%- endif -%}
]
{%- endcapture -%}

<div
  class="sugar-root{% if embed_mode %} sugar-root--embed{% endif %}"
  data-sugar-root
  data-sugar-theme="{{ theme_preset }}"
  style="{{ sugar_css_vars | strip }}"
  {% if embed_mode %}data-sugar-embed="true"{% endif %}
  {{ sugar_attributes }}
  data-sugar-config='{
    "proxyUrl": "/apps/sugar/generate",
    "imagePropertyKey": {{ image_property_key | json }},
    "generationIdPropertyKey": {{ generation_id_key | json }},
    "maxUploadSizeMb": {{ max_upload_mb | json }},
    "maxAdditionalProducts": {{ max_additional | json }},
    "customCss": {{ custom_css | json }},
    "modalTitle": {{ modal_title | json }},
    "modalSubtitle": {{ modal_subtitle | json }},
    "modalDescription": {{ modal_description | default: '' | json }},
    "instructionTemplate": {{ instruction | json }},
    "addDesignToCartLabel": {{ add_cart_label | json }},
    "loadingTitle": {{ loading_title | json }},
    "loadingSubtitle": {{ loading_subtitle | json }},
    "loadingEstimateSec": 50,
    "heroImageUrl": {{ upload_illustration_url | json }},
    "uploadIllustrationUrl": {{ upload_illustration_url | json }},
    "uploadIllustrationFit": {{ upload_illustration_fit | json }},
    "headerIconUrl": {% if settings.header_icon != blank %}{{ settings.header_icon | image_url: width: 64 | json }}{% else %}{{ header_icon_url | json }}{% endif %},
    "primaryButtonClasses": {{ primary_classes | json }},
    "secondaryButtonClasses": {{ secondary_classes | json }},
    "skipProductSelection": {% if skip_product_selection %}true{% else %}false{% endif %},
    "shopDomain": {{ shop.permanent_domain | json }},
    "maxSavedDesignsPerProduct": 20,
    "maxDesignAttempts": {{ max_design_attempts | json }},
    "productDetailMetafieldsJson": {{ product_detail_metafields_json | json }},
    "productDetailMetafieldNamespace": {{ product_detail_metafield_namespace | json }},
    "toastDurationMs": 3500,
    "locale": {{ shop_locale | json }},
    "i18n": {
      "modalDescription": {{ modal_description | json }},
      "errorUpload": {{ 'sugar.error_upload' | t | json }},
      "errorSize": {{ 'sugar.error_size' | t | json }},
      "errorRoomRequired": {{ 'sugar.error_room_required' | t | json }},
      "errorSelectProduct": {{ 'sugar.error_select_product' | t | json }},
      "errorGenerate": {{ 'sugar.error_generate' | t | json }},
      "errorGenerateProxy": {{ 'sugar.error_generate_proxy' | t | json }},
      "errorGenerateStorePassword": {{ 'sugar.error_generate_store_password' | t | json }},
      "errorGeneric": {{ 'sugar.error_generic' | t | json }},
      "errorCart": {{ 'sugar.error_cart' | t | json }},
      "errorCartRetry": {{ 'sugar.error_cart_retry' | t | json }},
      "cartSuccess": {{ 'sugar.cart_success' | t | json }},
      "cartSuccessDetail": {{ 'sugar.cart_success_detail' | t | json }},
      "cartView": {{ 'sugar.cart_view' | t | json }},
      "addCartLabel": {{ add_cart_label | json }},
      "savedDesignsLabel": {{ 'sugar.saved_designs_label' | t | json }},
      "savedDesignDelete": {{ 'sugar.saved_design_delete' | t | json }},
      "savedDesignProductCount": {{ 'sugar.saved_design_product_count' | t | json }},
      "galleryChoiceInstruction": {{ 'sugar.gallery_choice_instruction' | t | json }},
      "pickSavedDesigns": {{ 'sugar.pick_saved_designs' | t | json }},
      "pickNewPhoto": {{ 'sugar.pick_new_photo' | t | json }},
      "pickBack": {{ 'sugar.pick_back' | t | json }},
      "checklistDesign": {{ 'sugar.checklist_design' | t | json }},
      "checklistProducts": {{ 'sugar.checklist_products' | t | json }},
      "aiPreviewTitle": {{ 'sugar.ai_preview_title' | t | json }},
      "previewAlt": {{ 'sugar.preview_alt' | t | json }},
      "compareAria": {{ 'sugar.compare_aria' | t | json }},
      "compareOrigin": {{ 'sugar.compare_origin' | t | json }},
      "compareDesign": {{ 'sugar.compare_design' | t | json }},
      "compareShowOrigin": {{ 'sugar.compare_show_origin' | t | json }},
      "compareShowDesign": {{ 'sugar.compare_show_design' | t | json }},
      "cameraInstruction": {{ 'sugar.camera_instruction' | t | json }},
      "cameraCapture": {{ 'sugar.camera_capture' | t | json }},
      "cameraCancel": {{ 'sugar.camera_cancel' | t | json }},
      "roomPreviewLabel": {{ 'sugar.room_preview_label' | t | json }},
      "reviewInstruction": {{ 'sugar.review_instruction' | t | json }},
      "reviewInstructionOnly": {{ 'sugar.review_instruction_only' | t | json }},
      "mockupLabel": {{ 'sugar.mockup_label' | t | json }},
      "mockupDepth": {{ 'sugar.mockup_depth' | t | json }},
      "mockupDepthAria": {{ 'sugar.mockup_depth_aria' | t | json }},
      "mockupRemove": {{ 'sugar.mockup_remove' | t | json }},
      "productClickTip": {{ 'sugar.product_click_tip' | t | json }},
      "productEnableTip": {{ 'sugar.product_enable_tip' | t | json }},
      "qtyDecrease": {{ 'sugar.qty_decrease' | t | json }},
      "qtyIncrease": {{ 'sugar.qty_increase' | t | json }},
      "designButton": {{ 'sugar.design_button' | t | json }},
      "autoDesignButton": {{ 'sugar.auto_design_button' | t | json }},
      "errorPlacementRequired": {{ 'sugar.error_placement_required' | t | json }},
      "errorCamera": {{ 'sugar.error_camera' | t | json }},
      "redesignButton": {{ 'sugar.redesign_button' | t | json }},
      "redesignCount": {{ 'sugar.redesign_count' | t | json }},
      "redesignLimit": {{ 'sugar.redesign_limit' | t | json }},
      "editPlacement": {{ 'sugar.edit_placement' | t | json }},
      "errorDesignLimit": {{ 'sugar.error_design_limit' | t | json }},
      "loadingProgress": {{ 'sugar.loading_progress' | t | json }},
      "loadingTimeRemaining": {{ 'sugar.loading_time_remaining' | t | json }},
      "loadingComplete": {{ 'sugar.loading_complete' | t | json }},
      "loadingAlmostDone": {{ 'sugar.loading_almost_done' | t | json }},
      "designDownload": {{ 'sugar.design_download' | t | json }},
      "designDownloadSuccess": {{ 'sugar.design_download_success' | t | json }}
    }
  }'
  data-sugar-product='{
    "productId": {{ product.id | json }},
    "variantId": {{ selected_variant.id | json }},
    "title": {{ product.title | json }},
    "price": {{ selected_variant.price | json }},
    "currency": {{ shop_currency | json }},
    "imageUrl": {{ primary_image | image_url: width: 800 | json }},
    "images": {{ primary_images_json | strip_newlines }},
    "isPrimary": true
  }'
  data-sugar-catalog='{{ catalog_json | strip_newlines }}'
  data-sugar-variants='{{ variants_json | strip_newlines }}'
>
  <div class="sugar-trigger-wrap">
    <button type="button" class="{{ ai_btn_classes }}" data-sugar-open>
      <span class="sugar-ai-btn__sparkle" aria-hidden="true">{% render 'sugar-pdp-icons', icon: 'sparkle' %}</span>
      {{ button_label }}
      <span class="sugar-ai-btn__sparkle" aria-hidden="true">{% render 'sugar-pdp-icons', icon: 'sparkle' %}</span>
    </button>
    <p class="sugar-trigger-helper">{{ button_helper }}</p>
    <div class="sugar-saved-designs" data-sugar-saved-designs-page hidden>
      <p class="sugar-saved-designs__label">{{ 'sugar.saved_designs_label' | t }}</p>
      <div class="sugar-saved-designs__strip" data-sugar-saved-strip></div>
    </div>
  </div>

  <dialog
    class="sugar-dialog {{ modal_panel_classes }}"
    data-sugar-dialog
    data-sugar-theme="{{ theme_preset }}"
    style="{{ sugar_css_vars | strip }}"
  >
    <div class="sugar-modal">
      <div class="sugar-toast-host" data-sugar-toast-host aria-live="polite" aria-atomic="true">
        <div class="sugar-toast" data-sugar-toast hidden></div>
      </div>
      <div class="sugar-modal__header">
        <div class="sugar-modal__header-icon" data-sugar-header-icon>
          {%- if settings.header_icon != blank -%}
            <img src="{{ settings.header_icon | image_url: width: 64 }}" alt="" width="20" height="20" loading="lazy">
          {%- elsif header_icon_url != blank -%}
            <img src="{{ header_icon_url }}" alt="" width="20" height="20" loading="lazy">
          {%- else -%}
            {% render 'sugar-pdp-icons', icon: 'sparkle' %}
          {%- endif -%}
        </div>
        <div class="sugar-modal__header-text">
          <h2 class="sugar-modal__title">{{ modal_title }}</h2>
          <p class="sugar-modal__subtitle">{{ modal_subtitle }}</p>
        </div>
        <button type="button" class="sugar-modal__close" data-sugar-close aria-label="{{ 'sugar.close_aria' | t }}">
          {% render 'sugar-pdp-icons', icon: 'close' %}
        </button>
      </div>

      <div class="sugar-modal__body">
        <div class="sugar-step is-active" data-sugar-step="upload">
          <div class="sugar-upload-hero sugar-upload-hero--{{ upload_illustration_fit }}" data-sugar-upload-hero>
            <img
              class="sugar-upload-hero__img"
              src="{{ upload_illustration_url }}"
              alt=""
              loading="lazy"
              width="900"
              height="560"
              data-sugar-upload-illustration
            >
          </div>
          <div class="sugar-steps-label">
            <span class="is-active">{{ 'sugar.step_upload' | t }}</span>
            <span>{{ 'sugar.step_design' | t }}</span>
            <span>{{ 'sugar.step_view' | t }}</span>
          </div>
          <p class="sugar-instruction sugar-instruction--upload" data-sugar-upload-instruction></p>
          <div class="sugar-action-cards">
            <button type="button" class="sugar-action-card" data-sugar-open-gallery>
              <span class="sugar-action-card__icon" aria-hidden="true">
                {%- if gallery_icon_url != blank -%}
                  <img src="{{ gallery_icon_url }}" alt="" width="28" height="28" loading="lazy">
                {%- else -%}
                  {% render 'sugar-pdp-icons', icon: 'gallery' %}
                {%- endif -%}
              </span>
              <span class="sugar-action-card__label">{{ 'sugar.gallery_label' | t }}</span>
              <span class="sugar-action-card__sub">{{ 'sugar.gallery_sub' | t }}</span>
            </button>
            <button type="button" class="sugar-action-card" data-sugar-open-camera>
              <span class="sugar-action-card__icon" aria-hidden="true">
                {%- if camera_icon_url != blank -%}
                  <img src="{{ camera_icon_url }}" alt="" width="28" height="28" loading="lazy">
                {%- else -%}
                  {% render 'sugar-pdp-icons', icon: 'camera' %}
                {%- endif -%}
              </span>
              <span class="sugar-action-card__label">{{ 'sugar.camera_label' | t }}</span>
              <span class="sugar-action-card__sub">{{ 'sugar.camera_sub' | t }}</span>
            </button>
          </div>
          <input class="sugar-hidden-input" type="file" accept="image/*" id="sugar-gallery-{{ file_uid }}" data-sugar-file-gallery>
        </div>

        <div class="sugar-step" data-sugar-step="pick-source">
          <div class="sugar-step__scroll">
            <p class="sugar-instruction">{{ 'sugar.gallery_choice_instruction' | t }}</p>
            <p class="sugar-saved-designs__label">{{ 'sugar.pick_saved_designs' | t }}</p>
            <div class="sugar-saved-designs__strip sugar-saved-designs__strip--pick" data-sugar-pick-source-strip></div>
          </div>
          <div class="sugar-modal__actions">
            <button type="button" class="sugar-btn sugar-btn--back {{ secondary_classes }}" data-sugar-pick-source-back>
              {% render 'sugar-pdp-icons', icon: 'arrow-left' %}
              <span>{{ 'sugar.pick_back' | t }}</span>
            </button>
            <button type="button" class="sugar-btn {{ primary_classes }}" data-sugar-pick-new-photo>{{ 'sugar.pick_new_photo' | t }}</button>
          </div>
        </div>

        <div class="sugar-step" data-sugar-step="camera">
          <div class="sugar-step__scroll">
            <hr class="sugar-divider">
            <p class="sugar-instruction">{{ 'sugar.camera_instruction' | t }}</p>
            <div class="sugar-camera-wrap" data-sugar-camera-wrap>
              <video class="sugar-camera-video" data-sugar-camera-video autoplay playsinline muted webkit-playsinline></video>
              <p class="sugar-camera-loading">{{ 'sugar.camera_loading' | t }}</p>
            </div>
            <canvas class="sugar-hidden-input" data-sugar-camera-canvas></canvas>
          </div>
          <div class="sugar-modal__actions">
            <button type="button" class="sugar-btn sugar-btn--back {{ secondary_classes }}" data-sugar-camera-cancel>
              {% render 'sugar-pdp-icons', icon: 'arrow-left' %}
              <span>{{ 'sugar.camera_cancel' | t }}</span>
            </button>
            <button type="button" class="sugar-btn sugar-btn--capture {{ primary_classes }}" data-sugar-camera-capture>
              {% render 'sugar-pdp-icons', icon: 'shutter' %}
              <span>{{ 'sugar.camera_capture' | t }}</span>
            </button>
          </div>
        </div>

        <div class="sugar-step" data-sugar-step="products">
          <div class="sugar-step__scroll sugar-step__scroll--products">
            <p class="sugar-instruction" data-sugar-review-instruction></p>
            <p class="sugar-room-preview-label">{{ 'sugar.mockup_label' | t }}</p>
            <div class="sugar-mockup-stage" data-sugar-mockup-stage>
              <img class="sugar-mockup-stage__origin sugar-room-preview" data-sugar-room-preview alt="" width="600" height="450">
              <div class="sugar-mockup-stage__layers" data-sugar-mockup-layers></div>
            </div>
            <div class="sugar-mockup-scale" data-sugar-mockup-scale hidden>
              <label class="sugar-mockup-scale__label" for="sugar-depth-{{ file_uid }}">{{ 'sugar.mockup_depth' | t }}</label>
              <input
                type="range"
                class="sugar-mockup-scale__range"
                id="sugar-depth-{{ file_uid }}"
                data-sugar-mockup-scale-range
                min="12"
                max="55"
                step="1"
                value="28"
                aria-label="{{ 'sugar.mockup_depth_aria' | t }}"
              >
            </div>
          </div>
          <div class="sugar-products-panel" data-sugar-products-section>
            <p class="sugar-products-label">{{ 'sugar.products_label' | t }}</p>
            <div class="sugar-products-row">
              <div class="sugar-product-strip" data-sugar-product-strip></div>
            </div>
          </div>
          <div class="sugar-modal__actions">
            <button type="button" class="sugar-btn {{ secondary_classes }}" data-sugar-back-upload>{{ 'sugar.change_photo' | t }}</button>
            <button type="button" class="sugar-btn {{ primary_classes }}" data-sugar-design>
              <span data-sugar-design-label>{{ 'sugar.auto_design_button' | t }}</span>
            </button>
          </div>
        </div>

        <div class="sugar-step" data-sugar-step="loading">
          <div class="sugar-loading-wrap">
            <div class="sugar-spinner" aria-hidden="true"></div>
            <p class="sugar-loading-title">{{ loading_title }}</p>
            <p class="sugar-loading-sub">{{ loading_subtitle }}</p>
            <div
              class="sugar-loading-progress"
              data-sugar-loading-progress
              role="progressbar"
              aria-valuemin="0"
              aria-valuemax="100"
              aria-valuenow="0"
            >
              <div class="sugar-loading-progress__track">
                <div class="sugar-loading-progress__bar" data-sugar-loading-bar style="width: 0%"></div>
              </div>
              <p class="sugar-loading-progress__label" data-sugar-loading-progress-label aria-live="polite"></p>
            </div>
            <p class="sugar-loading-hint">{{ 'sugar.loading_browse_hint' | t }}</p>
          </div>
        </div>

        <div class="sugar-step" data-sugar-step="result">
          <div class="sugar-result-bar">
            <span class="sugar-result-bar__status">{{ 'sugar.result_ready' | t }}</span>
            <button type="button" class="sugar-result-bar__edit" data-sugar-redo>{{ 'sugar.edit_placement' | t }}</button>
          </div>
          <div class="sugar-design-preview" data-sugar-design-preview>
            <span class="sugar-design-preview__badge">{{ 'sugar.ai_preview_badge' | t }}</span>
            <span class="sugar-design-preview__demo-badge" data-sugar-demo-badge hidden>{{ 'sugar.demo_mode_badge' | t }}</span>
            <div class="sugar-design-preview__actions" data-sugar-design-actions hidden>
              <button
                type="button"
                class="sugar-design-preview__action"
                data-sugar-design-download
                aria-label="{{ 'sugar.design_download' | t }}"
              >
                {% render 'sugar-pdp-icons', icon: 'download' %}
              </button>
            </div>
            <div class="sugar-compare" data-sugar-compare style="--compare: 0%;">
              <img class="sugar-compare__img sugar-compare__img--origin" data-sugar-compare-origin alt="" width="800" height="600">
              <div class="sugar-compare__clip" data-sugar-compare-clip>
                <img class="sugar-compare__img sugar-compare__img--design" data-sugar-compare-design alt="" width="800" height="600">
              </div>
              <button
                type="button"
                class="sugar-compare__handle"
                data-sugar-compare-handle
                role="slider"
                aria-valuemin="0"
                aria-valuemax="100"
                aria-valuenow="0"
                aria-label="{{ 'sugar.compare_aria' | t }}"
              >
                <span class="sugar-compare__handle-icon" aria-hidden="true">
                  {% render 'sugar-pdp-icons', icon: 'compare-arrows' %}
                </span>
              </button>
              <button
                type="button"
                class="sugar-compare__tag sugar-compare__tag--origin is-active"
                data-sugar-compare-show="origin"
                aria-label="{{ 'sugar.compare_show_origin' | t }}"
              >
                {{ 'sugar.compare_origin' | t }}
              </button>
              <button
                type="button"
                class="sugar-compare__tag sugar-compare__tag--design"
                data-sugar-compare-show="design"
                aria-label="{{ 'sugar.compare_show_design' | t }}"
              >
                {{ 'sugar.compare_design' | t }}
              </button>
            </div>
          </div>
          <div class="sugar-redesign" data-sugar-redesign-wrap>
            <button type="button" class="sugar-redesign__btn" data-sugar-redesign>
              <span class="sugar-redesign__icon" aria-hidden="true">✦</span>
              <span data-sugar-redesign-label>{{ 'sugar.redesign_button' | t }}</span>
            </button>
            <span class="sugar-redesign__count" data-sugar-redesign-count aria-live="polite"></span>
          </div>
          <div class="sugar-checklist" data-sugar-checklist></div>
          <button type="button" class="sugar-btn-primary" data-sugar-add-design disabled>
            🛍 {{ add_cart_label }}
          </button>
        </div>
      </div>
    </div>
  </dialog>
</div>
