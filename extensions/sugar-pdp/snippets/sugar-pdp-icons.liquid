{% comment %}
  Inline SVG icons. Usage: {% render 'sugar-pdp-icons', icon: 'sparkle' %}
  Optional custom URL overrides via render params: custom_url
{% endcomment %}
{%- if custom_url != blank -%}
  <img class="sugar-icon sugar-icon--img" src="{{ custom_url }}" alt="" width="24" height="24" loading="lazy">
{%- else -%}
  {%- case icon -%}
    {%- when 'sparkle' -%}
      <svg class="sugar-icon sugar-icon--sparkle" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
        <path d="M11.017 2.814a1 1 0 0 1 1.966 0l1.051 5.558a2 2 0 0 0 1.594 1.594l5.558 1.051a1 1 0 0 1 0 1.966l-5.558 1.051a2 2 0 0 0-1.594 1.594l-1.051 5.558a1 1 0 0 1-1.966 0l-1.051-5.558a2 2 0 0 0-1.594-1.594l-5.558-1.051a1 1 0 0 1 0-1.966l5.558-1.051a2 2 0 0 0 1.594-1.594z"/>
        <path d="M20 2v4"/>
        <path d="M22 4h-4"/>
        <circle cx="4" cy="20" r="2"/>
      </svg>
    {%- when 'gallery' -%}
      <svg class="sugar-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
        <rect x="3" y="5" width="18" height="14" rx="2" fill="none" stroke="currentColor" stroke-width="1.6"/>
        <circle cx="9" cy="10" r="1.6" fill="currentColor"/>
        <path fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" d="M7 16l4-4 3 3 3-4 3 5"/>
      </svg>
    {%- when 'camera' -%}
      <svg class="sugar-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
        <path fill="none" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round" d="M4 8h3l1.5-2h7L17 8h3a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2v-8a2 2 0 0 1 2-2z"/>
        <circle cx="12" cy="13" r="3.2" fill="none" stroke="currentColor" stroke-width="1.6"/>
      </svg>
    {%- when 'close' -%}
      <svg class="sugar-icon sugar-icon--close" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
        <path fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" d="M7 7l10 10M17 7L7 17"/>
      </svg>
    {%- when 'arrow-left' -%}
      <svg class="sugar-icon sugar-icon--arrow-left" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
        <path fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M19 12H5"/>
        <path fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M12 19l-7-7 7-7"/>
      </svg>
    {%- when 'shutter' -%}
      <svg class="sugar-icon sugar-icon--shutter" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
        <circle cx="12" cy="12" r="8.5" fill="none" stroke="currentColor" stroke-width="1.8"/>
        <circle cx="12" cy="12" r="4.25" fill="currentColor"/>
      </svg>
    {%- when 'compare-arrows' -%}
      <svg class="sugar-icon sugar-icon--compare-arrows" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
        <path fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M8 7l-4 5 4 5"/>
        <path fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M16 7l4 5-4 5"/>
        <path fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" d="M4 12h16"/>
      </svg>
    {%- when 'download' -%}
      <svg class="sugar-icon sugar-icon--download" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
        <path fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M12 4v10"/>
        <path fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M8.5 10.5 12 14l3.5-3.5"/>
        <path fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" d="M5 18h14"/>
      </svg>
    {%- when 'upload' -%}
      <svg class="sugar-icon sugar-icon--upload" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
        <path fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M12 16V6"/>
        <path fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M8.5 9.5 12 6l3.5 3.5"/>
        <path fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M5 18h14"/>
      </svg>
  {%- endcase -%}
{%- endif -%}
