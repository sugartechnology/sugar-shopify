# Local Docker — kopyala: cp .env.local.example .env.local
# Çalıştır: docker compose up --build

NODE_ENV=development
HOST=0.0.0.0
PORT=3000
APP_PORT=3000

# Shopify Partners → Sugar Room Studio app
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SCOPES=read_products,write_products

# Local Docker'da app :3000 dinler; Shopify için HTTPS tunnel gerekir.
# Örnek: shopify app dev (tunnel) veya ngrok http 3000
SHOPIFY_APP_URL=https://your-tunnel-url.example.com

# OAuth session (SQLite — docker volume'da kalır)
DATABASE_URL=file:/app/prisma/dev.sqlite

# Sugar API — local'de genelde mock
SUGAR_API_BASE_URL=https://api.sugartech.io
SUGAR_API_MOCK=true

# Opsiyonel
# SHOP_CUSTOM_DOMAIN=
